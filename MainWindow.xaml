<Window x:Class="PortGhost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PortGhost" Height="520" Width="400" MinHeight="450" MinWidth="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource BgDarkBrush}" CornerRadius="10" BorderBrush="#334155" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Title Bar -->
                <RowDefinition Height="*"/> <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="Transparent">
                <TextBlock Text="👻 PortGhost" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Width="30" Background="Transparent" Click="Minimize_Click"/>
                    <Button Content="✕" Width="30" Background="Transparent" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <StackPanel Grid.Row="1" Margin="20" HorizontalAlignment="Stretch">
                
                <TextBlock Text="Enter Haunted Port" HorizontalAlignment="Center" Margin="0,10,0,5" Foreground="{StaticResource TextMutedBrush}"/>
                
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="PortInput" Text="3000" FontSize="20" TextAlignment="Center" Height="40" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    <Button x:Name="ScanBtn" Content="👻 Scan" Grid.Column="1" Width="100" Height="40" Background="{StaticResource GhostDormantBrush}" FontWeight="Bold" Click="ScanBtn_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20" x:Name="PresetButtonsPanel">
                    <Button Content="3000" Margin="0,0,5,0" Padding="5,2" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Click="Preset_Click"/>
                    <Button Content="8080" Margin="0,0,5,0" Padding="5,2" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Click="Preset_Click"/>
                    <Button Content="5173" Margin="0,0,5,0" Padding="5,2" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Click="Preset_Click"/>
                    <Button Content="4200" Padding="5,2" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Click="Preset_Click"/>
                </StackPanel>
                
                <!-- Ghost Avatar / Status -->
                <Border x:Name="GhostAvatar" Width="50" Height="50" CornerRadius="25" Background="#1E293B" HorizontalAlignment="Center" Margin="0,5,0,10" Effect="{StaticResource PanelShadow}">
                    <TextBlock x:Name="GhostIcon" Text="👻" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                </Border>
                
                <TextBlock x:Name="StatusText" Text="Ready to scan..." TextAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                
                <!-- Manifestation Details -->
                <Border x:Name="ManifestationPanel" Background="{StaticResource BgPanelBrush}" CornerRadius="10" Padding="20" Visibility="Collapsed" Effect="{StaticResource PanelShadow}">
                    <StackPanel>
                        <TextBlock Text="👻 GHOST MANIFESTATION" FontWeight="Bold" Foreground="{StaticResource HauntedBrush}" Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Spirit:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SpiritNameTxt" Text="node.exe" FontWeight="Bold" Margin="0,2"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Entity ID:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EntityIdTxt" Text="12345" Margin="0,2"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="From:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="FromPathTxt" Text="C:\projects\..." TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" Margin="0,2"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Started:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="StartedTxt" Text="2 hours ago" Margin="0,2"/>
                        </Grid>
                        
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button x:Name="ExorciseBtn" Grid.Column="0" Content="⚡ Exorcise" Background="{StaticResource HauntedBrush}" FontWeight="Bold" Click="ExorciseBtn_Click"/>
                            <Button x:Name="IgnoreBtn" Grid.Column="2" Content="Ignore" Click="IgnoreBtn_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
