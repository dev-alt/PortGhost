<Window x:Class="PortGhost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PortGhost" Height="600" Width="420" MinHeight="500" MinWidth="380"
        Icon="Assets/PortGhost.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="8" CaptionHeight="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource BgDarkBrush}" CornerRadius="10" BorderBrush="#334155" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>   <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="Transparent">
                <TextBlock Text="👻 PortGhost" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Width="30" Background="Transparent" Click="Minimize_Click"/>
                    <Button Content="✕" Width="30" Background="Transparent" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20" HorizontalAlignment="Stretch">

                    <TextBlock Text="Enter Haunted Port" HorizontalAlignment="Center" Margin="0,10,0,5" Foreground="{StaticResource TextMutedBrush}"/>

                    <!-- Port Input + Protocol Toggle + Scan -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PortInput" Text="3000" FontSize="20" TextAlignment="Center"
                                 Height="40" Margin="0,0,6,0" VerticalContentAlignment="Center"
                                 KeyDown="PortInput_KeyDown"/>

                        <!-- Protocol Selector -->
                        <ComboBox x:Name="ProtocolSelector" Grid.Column="1" Width="72" Height="40"
                                  Margin="0,0,6,0" VerticalContentAlignment="Center"
                                  Background="#1E293B" Foreground="White" BorderBrush="#475569"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="TCP"/>
                            <ComboBoxItem Content="UDP"/>
                            <ComboBoxItem Content="Both"/>
                        </ComboBox>

                        <Button x:Name="ScanBtn" Grid.Column="2" Content="👻 Scan"
                                Width="90" Height="40"
                                Background="{StaticResource GhostDormantBrush}" FontWeight="Bold"
                                Click="ScanBtn_Click"/>
                    </Grid>

                    <!-- Preset Buttons Row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ItemsControl x:Name="PresetButtonsPanel" Grid.Column="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <!-- Populated dynamically in code-behind -->
                        </ItemsControl>

                        <Button Grid.Column="1" Content="＋" Width="28" Height="24"
                                ToolTip="Add custom preset port"
                                Padding="0" FontSize="14" Margin="4,0,0,0"
                                Click="AddPreset_Click"/>
                    </Grid>

                    <!-- Ghost Sweep Button -->
                    <Button x:Name="SweepBtn" Content="🧹 Ghost Sweep All Presets"
                            Height="32" Margin="0,0,0,12"
                            Background="#4B3F72" FontSize="12" FontWeight="SemiBold"
                            Click="SweepBtn_Click"/>

                    <!-- Ghost Avatar / Status -->
                    <Border x:Name="GhostAvatar" Width="50" Height="50" CornerRadius="25"
                            Background="#1E293B" HorizontalAlignment="Center"
                            Margin="0,5,0,10" Effect="{StaticResource PanelShadow}">
                        <TextBlock x:Name="GhostIcon" Text="👻" FontSize="25"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                    </Border>

                    <TextBlock x:Name="StatusText" Text="Ready to scan..."
                               TextAlignment="Center" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Single-port Manifestation Details -->
                    <Border x:Name="ManifestationPanel" Background="{StaticResource BgPanelBrush}"
                            CornerRadius="10" Padding="20" Visibility="Collapsed"
                            Effect="{StaticResource PanelShadow}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="👻 GHOST MANIFESTATION" FontWeight="Bold"
                                       Foreground="{StaticResource HauntedBrush}" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Spirit:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SpiritNameTxt" Text="node.exe" FontWeight="Bold" Margin="0,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Protocol:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ProtocolTxt" Text="TCP" Margin="0,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Entity ID:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="EntityIdTxt" Text="12345" Margin="0,2"/>
                                <Button Grid.Row="2" Grid.Column="2" x:Name="CopyPidBtn" Content="📋"
                                        Padding="4,2" Margin="4,1,0,1" FontSize="11"
                                        ToolTip="Copy PID" Click="CopyPid_Click"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="From:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="FromPathTxt" Text="C:\projects\..."
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" Margin="0,2"/>
                                <Button Grid.Row="3" Grid.Column="2" x:Name="CopyPathBtn" Content="📋"
                                        Padding="4,2" Margin="4,1,0,1" FontSize="11"
                                        ToolTip="Copy path" Click="CopyPath_Click"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Started:" Foreground="{StaticResource TextMutedBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="StartedTxt" Text="2 hours ago" Margin="0,2"/>
                            </Grid>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ExorciseBtn" Grid.Column="0" Content="⚡ Exorcise"
                                        Background="{StaticResource HauntedBrush}" FontWeight="Bold"
                                        Click="ExorciseBtn_Click"/>
                                <Button x:Name="IgnoreBtn" Grid.Column="2" Content="Ignore"
                                        Click="IgnoreBtn_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Ghost Sweep Results Panel -->
                    <Border x:Name="SweepResultsPanel" Background="{StaticResource BgPanelBrush}"
                            CornerRadius="10" Padding="16" Visibility="Collapsed"
                            Effect="{StaticResource PanelShadow}">
                        <StackPanel>
                            <TextBlock x:Name="SweepHeaderTxt" Text="🧹 SWEEP RESULTS"
                                       FontWeight="Bold" Foreground="#A78BFA" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="SweepResultsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0F172A" CornerRadius="6" Padding="10,8"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontWeight="Bold">
                                                        <Run Text="{Binding Protocol}"/> <Run Text=" :"/> <Run Text="{Binding Port}"/>
                                                        <Run Text=" — "/> <Run Text="{Binding ProcessName}" Foreground="#EF4444"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ProcessId, StringFormat='PID: {0}'}"
                                                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="⚡"
                                                        Tag="{Binding ProcessId}"
                                                        ToolTip="Exorcise this ghost"
                                                        Padding="8,4" Background="#EF4444" FontWeight="Bold"
                                                        Click="SweepExorcise_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="SweepEmptyTxt" Text="✅ All preset ports are clear!"
                                       HorizontalAlignment="Center" Foreground="{StaticResource ClearBrush}"
                                       Visibility="Collapsed" Margin="0,4"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
